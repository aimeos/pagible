{
    "name": "aimeos/pagible-watch",
    "description": "Pagible CMS - Observability (structured logging and metrics)",
    "keywords": ["laravel", "cms", "logging", "observability", "audit"],
    "homepage": "https://pagible.com",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "aimeos/pagible-core": "*@dev"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0||^10.0||^11.0"
    },
    "autoload": {
        "psr-4": {
            "Aimeos\\Cms\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aimeos\\Cms\\WatchServiceProvider"
            ]
        }
    }
}
