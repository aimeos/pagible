{
    "name": "aimeos/pagible-mcp",
    "description": "Pagible CMS - MCP server and tools",
    "keywords": ["laravel", "cms", "mcp"],
    "homepage": "https://pagible.com",
    "type": "library",
    "license": "LGPL-3.0-only",
    "require": {
        "php": "^8.2",
        "aimeos/pagible-core": "*@dev",
        "laravel/mcp": "~0.5"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0||^10.0||^11.0"
    },
    "autoload": {
        "psr-4": {
            "Aimeos\\Cms\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aimeos\\Cms\\McpServiceProvider"
            ]
        }
    }
}
