{
    "name": "aimeos/pagible-themes-glass",
    "description": "Pagible CMS - Glass theme with dark glassmorphism design",
    "keywords": ["laravel", "cms", "theme", "glass", "glassmorphism"],
    "homepage": "https://pagible.com",
    "type": "library",
    "license": "LGPL-3.0-only",
    "require": {
        "php": "^8.2",
        "aimeos/pagible-theme": "*@dev"
    },
    "autoload": {
        "psr-4": {
            "Aimeos\\Cms\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aimeos\\Cms\\GlassServiceProvider"
            ]
        }
    }
}
