{
    "name": "aimeos/pagible-ai",
    "description": "Pagible CMS - AI features",
    "keywords": ["laravel", "cms", "ai"],
    "homepage": "https://pagible.com",
    "type": "library",
    "license": "LGPL-3.0-only",
    "prefer-stable": true,
    "minimum-stability": "dev",
    "require": {
        "php": "^8.2",
        "aimeos/pagible-mcp": "*@dev",
        "aimeos/pagible-core": "*@dev",
        "aimeos/pagible-graphql": "*@dev",
        "aimeos/prisma": "~0.4"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0||^10.0||^11.0"
    },
    "autoload": {
        "psr-4": {
            "Aimeos\\Cms\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aimeos\\Cms\\AiServiceProvider"
            ]
        }
    }
}
